{
  "name": "myselec-crm",
  "version": "1.0.0",
  "description": "CRM Comercial MySelec - Sistema de Gestión de Cotizaciones y Órdenes de Compra",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "seed": "node prisma/seed.js",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "setup": "npm run db:push && npm run db:generate && npm run seed",
    "build": "npx prisma generate",
    "start": "node src/server.js",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^172.0.0",
    "helmet": "^8.2.0",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.8",
    "pdf-parse": "^1.1.1",
    "resend": "^4.8.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.6.0"
  }
}
